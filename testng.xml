<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="OrangeHRM Test Suite">
    <listeners>
        <listener class-name="com.orangehrm.listeners.ExtentReportListener"/>
    </listeners>

    <test name="Login Tests">
        <classes>
            <class name="com.orangehrm.test.LoginTest"/>
        </classes>
    </test>

    <test name="Logout Tests">
        <classes>
            <class name="com.orangehrm.test.LogoutTest"/>
        </classes>
    </test>

    <test name="Admin Tests">
        <classes>
            <class name="com.orangehrm.test.AdminTest"/>
        </classes>
    </test>

    <test name="PIM Tests">
        <classes>
            <class name="com.orangehrm.test.PIMTest"/>
        </classes>
    </test>
</suite>
